@model List<TalabatSmartVillage.ViewModel.CartViewModels.CartItemViewModel>

@{
    ViewData["Title"] = "Your Cart";
    var total = Model.Sum(x => x.LineTotal);
}

<div class="container py-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2"></i>Your Cart</h2>

    @if (TempData["CartMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i> @TempData["CartMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x text-muted" style="font-size:4rem;"></i>
            <h4 class="mt-3 fw-bold">Your cart is empty</h4>
            <p class="text-muted">Add some delicious items from a restaurant to get started.</p>
            <a asp-controller="Restaurant" asp-action="Index" class="btn btn-danger mt-2">
                <i class="bi bi-shop me-1"></i>Browse Restaurants
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        @foreach (var item in Model)
                        {
                            <div class="d-flex align-items-center gap-3 p-3 border-bottom cart-item">
                                @if (!string.IsNullOrWhiteSpace(item.Image))
                                {
                                    <img src="@item.Image" class="rounded" style="width:70px;height:70px;object-fit:cover;" alt="@item.Name" />
                                }
                                else
                                {
                                    <div class="rounded bg-light d-flex align-items-center justify-content-center" style="width:70px;height:70px;">
                                        <i class="bi bi-egg-fried text-muted fs-4"></i>
                                    </div>
                                }
                                <div class="flex-grow-1">
                                    <div class="fw-bold">@item.Name</div>
                                    <div class="text-muted small">@item.UnitPrice.ToString("C") each</div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                        <button type="submit" name="quantity" value="@(item.Quantity - 1)"
                                                class="btn btn-outline-secondary btn-sm">-</button>
                                        <span class="px-2 fw-bold">@(item.Quantity)</span>
                                        <button type="submit" name="quantity" value="@(item.Quantity + 1)"
                                                class="btn btn-outline-secondary btn-sm">+</button>
                                    </form>
                                    <span class="fw-bold text-primary ms-2" style="min-width:70px;text-align:right;">@item.LineTotal.ToString("C")</span>
                                    <form asp-action="Remove" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="menuItemId" value="@item.MenuItemId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-white d-flex justify-content-end">
                        <form asp-action="Clear" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('Clear your entire cart?')">
                                <i class="bi bi-x-circle me-1"></i>Clear Cart
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm p-4 sticky-top" style="top:80px;">
                    <h5 class="fw-bold mb-3">Order Summary</h5>
                    @foreach (var item in Model)
                    {
                        <div class="d-flex justify-content-between small mb-1">
                            <span class="text-muted">@item.Name x @item.Quantity</span>
                            <span>@item.LineTotal.ToString("C")</span>
                        </div>
                    }
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                        <span>Total</span>
                        <span class="text-primary">@total.ToString("C")</span>
                    </div>
                    <a asp-controller="Checkout" asp-action="Index" class="btn btn-danger w-100 fw-bold py-2">
                        <i class="bi bi-credit-card me-1"></i>Proceed to Checkout
                    </a>
                    <a asp-controller="Restaurant" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                        <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                    </a>
                </div>
            </div>
        </div>
    }
</div>
