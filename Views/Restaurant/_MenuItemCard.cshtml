@model TalabatSmartVillage.ViewModel.MenuItemViewModels.MenuItemCardViewModel

<div class="card h-100 border-0 shadow-sm menu-card">
    <div class="position-relative">
        @if (!string.IsNullOrWhiteSpace(Model.Image))
        {
            <img src="@Model.Image" class="card-img-top menu-card-image" alt="@Model.Name" />
        }
        else
        {
            <div class="menu-card-placeholder d-flex align-items-center justify-content-center">
                <i class="bi bi-image text-muted"></i>
            </div>
        }
        <span class="badge position-absolute top-0 end-0 m-2 @(Model.IsAvailable ? "bg-success" : "bg-secondary")">
            @(Model.IsAvailable ? "Available" : "Unavailable")
        </span>
    </div>
    <div class="card-body d-flex flex-column">
        <h5 class="fw-bold">@Model.Name</h5>
        <p class="text-muted small flex-grow-1">@Model.Description</p>
        <span class="badge rounded-pill bg-light text-dark border align-self-start">@Model.Category</span>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <span class="fw-bold text-primary">@Model.Price.ToString("C")</span>
            <form asp-action="AddToCart" method="post" class="mb-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="menuItemId" value="@Model.Id" />
                <input type="hidden" name="restaurantId" value="ViewBag.RestaurantId" />
                <button class="btn btn-sm btn-outline-primary" @(Model.IsAvailable ? "" : "disabled")>Add to cart</button>
            </form>
        </div>
    </div>
</div>
