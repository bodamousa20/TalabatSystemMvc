@model TalabatSmartVillage.Models.Category

<div class="container py-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-5">
            <div class="p-5 bg-white rounded shadow-lg border border-danger border-opacity-10">
                <div class="mb-4">
                    <i class="bi bi-trash3 text-danger" style="font-size: 4rem;"></i>
                </div>
                <h2 class="fw-bold">Are you sure?</h2>
                <p class="text-muted mb-4">You are about to remove <strong>@Model.Name</strong>. This may affect menu visibility for restaurants.</p>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" /> [cite: 4]
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg py-3 fw-bold">Confirm Deletion</button>
                        <a asp-action="Index" class="btn btn-light py-2">Cancel and Keep</a> [cite: 5]
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>