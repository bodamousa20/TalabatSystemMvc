@model TalabatSmartVillage.Models.Category

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg border-top border-warning border-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-4">Edit @Model.Name</h4>
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" /> [cite: 8]
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Update Name</label>
                            <input asp-for="Name" class="form-control border-2" /> [cite: 9]
                            <span asp-validation-for="Name" class="text-danger small"></span> [cite: 9]
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="text-decoration-none text-muted"><i class="bi bi-chevron-left"></i> Back</a>
                            <button type="submit" class="btn btn-warning px-5 fw-bold">Update</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>