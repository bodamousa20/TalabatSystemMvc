@model TalabatSmartVillage.Models.Category

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg">
                <div class="card-body p-4 text-center">
                    <h4 class="fw-bold mb-3">New Category</h4>
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div> [cite: 1]

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label text-muted small text-uppercase fw-bold d-block text-start">Name</label>
                            <input asp-for="Name" class="form-control form-control-lg bg-light border-0" placeholder="Enter category name" /> [cite: 1]
                            <span asp-validation-for="Name" class="text-danger small"></span> [cite: 2]
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg shadow-sm">Save Category</button>
                            <a asp-action="Index" class="btn btn-link text-muted">Go Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>