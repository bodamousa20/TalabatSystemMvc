@model TalabatSmartVillage.ViewModel.OrderViewModels.OrderHistoryViewModel

@{
    ViewData["Title"] = "Order History";
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4">
        <div>
            <h2 class="fw-bold">Order History</h2>
            <p class="text-muted">Review your recent orders and their current status.</p>
        </div>
        <span class="badge rounded-pill bg-light text-dark border">Total Orders: @Model.TotalOrders</span>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="alert alert-light border text-center p-5">
            <i class="bi bi-basket display-6 d-block mb-3"></i>
            <h4 class="fw-bold">No orders yet</h4>
            <p class="text-muted mb-0">Once you place an order, it will appear here.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model.Orders)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white border-0 d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                <h5 class="fw-bold mb-1">Order #@order.Id</h5>
                                <span class="text-muted small">Placed @order.PlacedAt.ToString("MMM dd, yyyy • hh:mm tt")</span>
                            </div>
                            <span class="badge @order.StatusBadgeClass">@order.Status</span>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-8">
                                    <h6 class="text-uppercase text-muted small">Items</h6>
                                    <ul class="list-group list-group-flush">
                                        @foreach (var item in order.Items)
                                        {
                                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                                <div>
                                                    <span class="fw-bold">@item.Name</span>
                                                    <span class="text-muted">x@item.Quantity</span>
                                                </div>
                                                <span class="fw-bold">@item.LineTotal.ToString("C")</span>
                                            </li>
                                        }
                                    </ul>
                                </div>
                                <div class="col-lg-4">
                                    <div class="bg-light rounded-3 p-3 h-100">
                                        <h6 class="text-uppercase text-muted small">Summary</h6>
                                        <div class="d-flex justify-content-between mb-2">
                                            <span>Total</span>
                                            <span class="fw-bold">@order.TotalOrderPrice.ToString("C")</span>
                                        </div>
                                        <div class="d-flex justify-content-between">
                                            <span>Status</span>
                                            <span class="fw-bold">@order.Status</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <nav class="mt-4" aria-label="Order history pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                </li>
                @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                {
                    <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@pageNumber">@pageNumber</a>
                    </li>
                }
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>
