@model TalabatSmartVillage.ViewModel.UserViewModels.UserProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="profile-avatar">
                    @Model.FullName.Substring(0, 1).ToUpper()
                </div>
                <div>
                    <h3 class="fw-bold mb-0">@Model.FullName</h3>
                    <p class="text-muted mb-0">@Model.Email</p>
                    <span class="badge bg-danger">@Model.Roles</span>
                </div>
            </div>

            @if (ViewData["StatusMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle me-1"></i>@ViewData["StatusMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">Edit Profile</h5>
                </div>
                <div class="card-body px-4">
                    <form asp-action="Profile" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label fw-semibold"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input value="@Model.Email" class="form-control" disabled />
                            <div class="form-text">Email cannot be changed.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PhoneNumber" class="form-label fw-semibold"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-semibold"></label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PostalCode" class="form-label fw-semibold"></label>
                            <input asp-for="PostalCode" class="form-control" type="number" />
                            <span asp-validation-for="PostalCode" class="text-danger small"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger fw-semibold">Save Changes</button>
                            <a asp-controller="User" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-white border-0 px-4 pb-4">
                    <small class="text-muted">
                        <i class="bi bi-calendar me-1"></i>Member since @Model.CreatedAt.ToString("MMMM yyyy")
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
