@model TalabatSmartVillage.ViewModel.MenuItemViewModels.MenuItemCardViewModel

<div class="card h-100 border-0 shadow-sm menu-card">
    <div class="position-relative">
        @if (!string.IsNullOrWhiteSpace(Model.Image))
        {
            <img src="@Model.Image" class="card-img-top menu-card-image" alt="@Model.Name" />
        }
        else
        {
            <div class="menu-card-placeholder d-flex align-items-center justify-content-center bg-light">
                <i class="bi bi-egg-fried text-muted" style="font-size:2.5rem;"></i>
            </div>
        }
        <span class="badge position-absolute top-0 end-0 m-2 @(Model.IsAvailable ? "bg-success" : "bg-secondary")">
            @(Model.IsAvailable ? "Available" : "Unavailable")
        </span>
    </div>
    <div class="card-body d-flex flex-column">
        <h6 class="fw-bold mb-1">@Model.Name</h6>
        <p class="text-muted small flex-grow-1">@Model.Description</p>
        <span class="badge rounded-pill bg-light text-dark border align-self-start mb-2">@Model.Category</span>
        <div class="d-flex justify-content-between align-items-center mt-auto">
            <span class="fw-bold text-primary fs-6">@Model.Price.ToString("C")</span>
            @if (Model.IsAvailable)
            {
                <form asp-controller="Restaurant" asp-action="AddToCart" method="post" class="mb-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="menuItemId" value="@Model.Id" />
                    <input type="hidden" name="restaurantId" value="@Model.RestaurantId" />
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="bi bi-cart-plus me-1"></i>Add
                    </button>
                </form>
            }
            else
            {
                <button class="btn btn-sm btn-outline-secondary" disabled>Unavailable</button>
            }
        </div>
    </div>
</div>
