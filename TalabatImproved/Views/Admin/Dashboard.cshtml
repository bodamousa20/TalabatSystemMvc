@model TalabatSmartVillage.ViewModel.AdminViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Admin Dashboard</h2>
            <p class="text-muted mb-0">System overview and quick stats.</p>
        </div>
        <a asp-action="Orders" class="btn btn-danger">
            <i class="bi bi-list-check me-1"></i>Manage Orders
        </a>
    </div>

    <!-- Stats Row -->
    <div class="row g-4 mb-4">
        @{
            var stats = new[]
            {
                new { Label = "Restaurants", Value = Model.RestaurantCount.ToString(), Icon = "bi-shop", Color = "bg-primary" },
                new { Label = "Categories", Value = Model.CategoryCount.ToString(), Icon = "bi-tags", Color = "bg-success" },
                new { Label = "Menu Items", Value = Model.MenuItemCount.ToString(), Icon = "bi-list-ul", Color = "bg-warning" },
                new { Label = "Users", Value = Model.UserCount.ToString(), Icon = "bi-people", Color = "bg-info" },
                new { Label = "Total Orders", Value = Model.OrderCount.ToString(), Icon = "bi-basket", Color = "bg-danger" },
                new { Label = "Pending Orders", Value = Model.PendingOrderCount.ToString(), Icon = "bi-hourglass-split", Color = "bg-orange" },
            };
        }
        @foreach (var stat in stats)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm stat-card h-100">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between">
                            <div>
                                <p class="text-muted mb-1 small text-uppercase fw-semibold">@stat.Label</p>
                                <h3 class="fw-bold mb-0">@stat.Value</h3>
                            </div>
                            <div class="stat-icon @stat.Color text-white">
                                <i class="bi @stat.Icon"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Revenue Card -->
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-bold mb-1">Total Revenue</h5>
                <p class="text-muted small">From delivered orders</p>
                <div class="display-5 fw-bold text-success mt-2">@Model.TotalRevenue.ToString("C")</div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-bold mb-3">Quick Links</h5>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Admin" asp-action="Orders" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-basket me-1"></i>Orders
                    </a>
                    <a asp-controller="Restaurant" asp-action="Index" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-shop me-1"></i>Restaurants
                    </a>
                    <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-tags me-1"></i>Categories
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
