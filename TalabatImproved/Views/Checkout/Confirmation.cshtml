@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="mb-4">
                <i class="bi bi-check-circle-fill text-success" style="font-size:5rem;"></i>
            </div>
            <h2 class="fw-bold">Order Placed Successfully!</h2>
            <p class="text-muted fs-5 mt-2">
                Thank you for your order. We're preparing your food right now! 🍕
            </p>

            <div class="card border-0 shadow-sm p-4 my-4 text-start">
                <h5 class="fw-bold mb-3">What's next?</h5>
                <div class="d-flex gap-3 mb-2">
                    <i class="bi bi-1-circle-fill text-danger fs-5 flex-shrink-0"></i>
                    <span>Your order has been confirmed and sent to the restaurant.</span>
                </div>
                <div class="d-flex gap-3 mb-2">
                    <i class="bi bi-2-circle-fill text-danger fs-5 flex-shrink-0"></i>
                    <span>The restaurant is now preparing your food.</span>
                </div>
                <div class="d-flex gap-3">
                    <i class="bi bi-3-circle-fill text-danger fs-5 flex-shrink-0"></i>
                    <span>Your delivery is on its way!</span>
                </div>
            </div>

            @if (ViewBag.OrderId != null)
            {
                <p class="text-muted">Order Reference: <strong>#@ViewBag.OrderId</strong></p>
            }

            <div class="d-flex justify-content-center gap-3 mt-4">
                <a asp-controller="User" asp-action="Index" class="btn btn-outline-danger">
                    <i class="bi bi-clock-history me-1"></i>My Orders
                </a>
                <a asp-controller="Restaurant" asp-action="Index" class="btn btn-danger">
                    <i class="bi bi-shop me-1"></i>Order More
                </a>
            </div>
        </div>
    </div>
</div>
