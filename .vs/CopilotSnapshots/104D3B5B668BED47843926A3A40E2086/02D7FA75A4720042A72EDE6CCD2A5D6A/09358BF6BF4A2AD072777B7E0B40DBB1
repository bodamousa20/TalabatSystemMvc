using System.Linq;
using Microsoft.EntityFrameworkCore;
using TalabatSmartVillage.Models;
using TalabatSmartVillage.Repositories.Interfaces;
using TalabatSmartVillage.ViewModel.RestaurantViewModels;

namespace TalabatSmartVillage.Repositories.RepoImplementations
{
    public class RestaurantRepo : IRestaurantRepo
    {
        private readonly AppDbContext _appDbContext;
        public RestaurantRepo(AppDbContext Context)
        {
            _appDbContext = Context;
        }
        public void Create(RestaurantFormViewModel vm)
        {
            if (vm == null)
                throw new ArgumentNullException(nameof(vm));

            var restaurant = new Restaurant
            {
                Name = vm.Name,
                Address = vm.Address,
                CategoryId = vm.CategoryId,
                IsOpen = vm.IsOpen
            };

            _appDbContext.restaurant.Add(restaurant);
            _appDbContext.SaveChanges();
        }

        public void Delete(int id)
        {
            var restaurant = _appDbContext.restaurant.Find(id);
            if (restaurant == null)
                throw new KeyNotFoundException($"Restaurant with ID {id} not found.");

            _appDbContext.restaurant.Remove(restaurant);
            _appDbContext.SaveChanges();
        }

        public IEnumerable<RestaurantListViewModel> GetAll()
        {
            return _appDbContext.restaurant
                .Include(r => r.Category)
                .Select(r => new RestaurantListViewModel
                {
                    Id = r.Id,
                    Name = r.Name,
                    Address = r.Address,
                    CategoryName = r.Category.Name,
                    IsOpen = r.IsOpen
                })
                .ToList();
        }

        public RestaurantDetailsViewModel GetById(int id)
        {
            var restaurant = _appDbContext.restaurant
                .Include(r => r.Category)
                .FirstOrDefault(r => r.Id == id);

            if (restaurant == null)
                throw new KeyNotFoundException($"Restaurant with ID {id} not found.");

            return new RestaurantDetailsViewModel
            {
                Id = restaurant.Id,
                Name = restaurant.Name,
                Address = restaurant.Address,
                CategoryName = restaurant.Category.Name,
                IsOpen = restaurant.IsOpen
            };
        }

        public void Update(RestaurantFormViewModel vm)
        {
            if (vm == null)
                throw new ArgumentNullException(nameof(vm));

            var restaurant = _appDbContext.restaurant.Find(vm.Id);
            if (restaurant == null)
                throw new KeyNotFoundException($"Restaurant with ID {vm.Id} not found.");

            restaurant.Name = vm.Name;
            restaurant.Address = vm.Address;
            restaurant.CategoryId = vm.CategoryId;
            restaurant.IsOpen = vm.IsOpen;

            _appDbContext.restaurant.Update(restaurant);
            _appDbContext.SaveChanges();
        }
    }
}
